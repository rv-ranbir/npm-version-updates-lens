{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Extension Development Host)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}

